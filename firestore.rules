rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(uid())) &&
         get(/databases/$(database)/documents/users/$(uid())).data.role in ['admin', 'administrador', 'ADMIN'] &&
         get(/databases/$(database)/documents/users/$(uid())).data.isActive == true)
      );
    }
    
    function isStaff() {
      return isAdmin() || (isSignedIn() && (
        request.auth.token.role == 'tutor' ||
        (exists(/databases/$(database)/documents/users/$(uid())) &&
         get(/databases/$(database)/documents/users/$(uid())).data.role == 'tutor' &&
         get(/databases/$(database)/documents/users/$(uid())).data.isActive == true)
      ));
    }

    function isEnrolled(courseId) {
      let enrollmentId = uid() + '_' + courseId;
      return exists(/databases/$(database)/documents/enrollments/$(enrollmentId))
             && get(/databases/$(database)/documents/enrollments/$(enrollmentId)).data.status in ['active', 'completed'];
    }

    // Default: Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow read, write: if isSignedIn() && userId == uid();
      allow read, write: if isAdmin();
      
      // subcollections like enrollments
      match /enrollments/{courseId} {
        allow read: if isSignedIn() && userId == uid();
        allow write: if isAdmin(); // Server only
      }

      match /notifications/{notificationId} {
        allow read, update: if isSignedIn() && userId == uid();
        allow read, write: if isAdmin();
      }
    }

    // COURSES
    match /courses/{courseId} {
      allow read: if isAdmin() || isStaff() || isEnrolled(courseId) || resource.data.isPublished == true; 
      allow write: if isAdmin() || isStaff();

      match /modules/{moduleId} {
        allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
        allow write: if isAdmin() || isStaff();
      }

      match /lessons/{lessonId} {
        allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
        allow write: if isAdmin() || isStaff();

        match /blocks/{blockId} {
            allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
            allow write: if isAdmin() || isStaff();
        }
      }

      match /materials/{materialId} {
        allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
        allow write: if isAdmin() || isStaff();
      }

      match /announcements/{announcementId} {
        allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
        allow write: if isAdmin() || isStaff();
      }

      match /communityThreads/{threadId} {
        allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
        allow create: if isEnrolled(courseId);
        allow update, delete: if isAdmin() || isStaff() || (isSignedIn() && resource.data.authorId == uid());

        match /replies/{replyId} {
          allow read: if isAdmin() || isStaff() || isEnrolled(courseId);
          allow create: if isEnrolled(courseId);
          allow update, delete: if isAdmin() || isStaff() || (isSignedIn() && resource.data.authorId == uid());
        }
      }
    }

    // GLOBAL COMMUNITY THREADS
    match /community_threads/{threadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isStaff() || (isSignedIn() && resource.data.authorId == uid());
    }

    // GLOBAL ENROLLMENTS
    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == uid());
      allow write: if false; // Writes should be handled by server/admin
    }

    // TRANSACTIONS / PAYMENTS
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == uid());
      allow create: if isSignedIn() && request.resource.data.userId == uid();
      allow update, delete: if false; // Server only
    }

    // PROGRESS
    match /progress/{progressId} {
      allow read: if isAdmin() || isStaff() || (isSignedIn() && resource.data.userId == uid());
      allow write: if isSignedIn() && request.resource.data.userId == uid();
    }

    // CERTIFICATES
    match /certificates/{certificateId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == uid());
      allow write: if false; // Issued by backend
    }

    // EVENTS
    match /events/{eventId} {
      allow read: if isAdmin() || resource.data.isPublic == true || (resource.data.enrolledOnly == true && isEnrolled(resource.data.courseId));
      allow write: if isAdmin();
    }

    // AUDIT & SYSTEM
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /system/{docId} {
      allow read: if true; 
      allow write: if false;
    }

    // SITE SETTINGS (Public info)
    match /siteSettings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // GALLERY (Public)
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ASSESSMENT SUBMISSIONS
    match /assessmentSubmissions/{submissionId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.studentId == uid());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // PUBLIC DOCUMENTS
    match /publicDocs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BLOG POSTS
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PUBLIC GALLERY (Extended)
    match /publicGallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PUBLIC LIBRARY
    match /publicLibrary/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // STATIC PAGES
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TEAM MEMBERS
    match /team_members/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PRESENCE (Real-time)
    match /presence/{presenceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (presenceId.startsWith(uid()) || isAdmin());
    }

    // APPLICATIONS / INTERESTS
    match /applications/{appId} {
      allow read, write: if isAdmin();
      allow create: if true; // Public can submit interest
    }

    // GAMIFICATION
    match /gamification_profiles/{profileId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // STATS & INTERACTION
    match /stats/{statId} {
      allow read: if true;
      allow write: if statId == 'tree'; // Allow public increment for the Feelings Tree
    }

    // ANALYTICS (Optional/Pre-emptive)
    match /analytics_events/{eventId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
